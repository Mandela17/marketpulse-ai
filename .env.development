# ─── MarketPulse AI — Development Environment ───
# These values are defaults for `next dev`. Secrets should go in .env.local (gitignored).

# App URL (localhost for development)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Upstox API — Client ID is public (used in OAuth redirect URL)
# NEXT_PUBLIC_UPSTOX_CLIENT_ID=  (set in .env.local)
# UPSTOX_CLIENT_SECRET=          (set in .env.local — server-side only)
